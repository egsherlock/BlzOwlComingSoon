		font-size: var(--text-xsmall);
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--color-faint);
		font-variant-numeric: tabular-nums;
		text-align: right;
		/* Hidden the moment we cross into the monolith zone — one clock only. */
