			rgb(var(--color-primary-light-rgb) / 0.4),
			rgb(var(--color-primary-dark-rgb) / 0.12) 60%,
			#0a0a0a
		);
	}
	.csm-cap-top {
		transform: rotateX(90deg) translateZ(var(--hw));
	}
	.csm-cap-bottom {
		top: auto;
		bottom: 0;
		transform: rotateX(-90deg) translateZ(var(--hw));
	}

	/* The scroll-driven orbit wrapper (base: neutral; the turn lives in the
	   gated block below so RM/no-support keep the prism parked). */
	.csm-orbit {
		width: 100%;
		height: 100%;
		transform-style: preserve-3d;
	}

	/* ---- ZONE 2's SCROLL-DRIVEN STORY --------------------------------------
	   The whole zone publishes a named view-timeline (--csmz2); every arrival
	   scrubs against it — pure CSS, no JS, portable. Zone 2 is min 100svh, so
	   its cover progress at "settled" (zone filling the viewport) is ~50% —
	   and the HARD GUARANTEE (owner round 5) is that every reveal reaches 100%
	   at or safely before maximum scroll on EVERY viewport: worst case is a
	   phone whose dynamic toolbar makes svh ≈ 0.85 × innerHeight, putting the
	   settled cover progress near 44%, so ALL ranges end ≤42%. (.csm clips
	   vertical overflow, so nothing — light included — can add scroll distance
	   past the monolith's own end and break the settle point.)
	     · the prism ORBITS ~150° into place (composing with the idle turn),
	     · it rises + resolves as a discovered object,
	     · the floor line draws in,
	     · the content lifts out of clip masks in a staggered cascade.
	   Where animation-timeline is unsupported (and under RM) everything below
	   is skipped — the zone is simply visible, static. ---------------------- */
	@media (prefers-reduced-motion: no-preference) {
		@supports (animation-timeline: view()) {
			/* All CSS-timeline rules are gated on :not(.csm-scrub-js): when the JS
			   fallback takes over (view-timeline unsupported, or forced for test),
			   it stamps .csm-scrub-js on the root, turning these off so JS's inline
			   transforms are the single source of truth — no CSS-vs-JS conflict. */
			.csm:not(.csm-scrub-js) .csm-monolith {
				view-timeline: --csmz2 block;
			}
			.csm:not(.csm-scrub-js) .csm-orbit {
				animation: csm-orbit linear both;
				animation-timeline: --csmz2;
				animation-range: cover 0% cover 42%;
			}
			.csm:not(.csm-scrub-js) .csm-stage3d {
				animation: csm-rise linear both;
				animation-timeline: --csmz2;
				animation-range: cover 2% cover 30%;
			}
			.csm:not(.csm-scrub-js) .csm-floor {
				animation: csm-floor-draw linear both;
				animation-timeline: --csmz2;
				animation-range: cover 8% cover 34%;
			}
			/* The clip masks + lifts (§7 masked reveals — never bare fades). */
			.csm-rev {
				clip-path: inset(-0.3em -0.3em -0.1em -0.3em);
			}
			.csm:not(.csm-scrub-js) .csm-rev > * {
				animation: csm-lift linear both;
				animation-timeline: --csmz2;
			}
			/* ⚠ The per-rev ranges MUST carry the same .csm:not(.csm-scrub-js)
			   prefix as the shorthand rule above: the `animation` SHORTHAND resets
			   animation-range to `normal`, so if these were lower-specificity the
			   reset would win and every lift would run cover 0→100% — freezing all
			   the zone-2 text at 65% inside its mask at the settled bottom (the
			   round-5 owner screenshot; introduced by round 4's rescope). */
			.csm:not(.csm-scrub-js) .csm-rev-1 > * {
				animation-range: cover 14% cover 25%;
			}
			.csm:not(.csm-scrub-js) .csm-rev-2 > * {
				animation-range: cover 17% cover 28%;
			}
			.csm:not(.csm-scrub-js) .csm-rev-3 > * {
				animation-range: cover 20% cover 31%;
			}
			.csm:not(.csm-scrub-js) .csm-rev-4 > * {
				animation-range: cover 23% cover 34%;
			}
			.csm:not(.csm-scrub-js) .csm-rev-5 > * {
				animation-range: cover 26% cover 36%;
			}
			.csm:not(.csm-scrub-js) .csm-rev-6 > * {
				animation-range: cover 29% cover 39%;
			}
			.csm:not(.csm-scrub-js) .csm-rev-7 > * {
				animation-range: cover 32% cover 42%;
			}
			@keyframes csm-orbit {
				from {
					transform: rotateX(7deg) rotateY(-150deg);
				}
				to {
					transform: rotateX(0deg) rotateY(0deg);
				}
			}
			@keyframes csm-rise {
				from {
					opacity: 0;
					transform: translateY(9vh) scale(0.9);
				}
				to {
					opacity: 1;
					transform: translateY(0) scale(1);
				}
			}
			@keyframes csm-floor-draw {
				from {
					transform: translateX(-50%) scaleX(0);
				}
				to {
					transform: translateX(-50%) scaleX(1);
				}
			}
			@keyframes csm-lift {
				from {
					transform: translateY(130%);
				}
				to {
					transform: translateY(0);
				}
			}
		}
	}

	/* ---- Zone-2 content --------------------------------------------------- */
	.csm-inner {
		position: relative;
		width: 100%;
		max-width: 40rem;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	/* The canonical wordmark — leads the entrance cascade. */
	.csm-wordmark {
		margin: 0 0 clamp(1.1rem, 2.5vw, 1.6rem);
	}
	.csm-wordmark svg {
		display: block;
		width: clamp(8.75rem, 26vw, 12rem);
		height: auto;
	}
	.csm-wordmark .wm-a {
		fill: url(#csm-wm-g);
	}
	.csm-wordmark .wm-b {
		fill: var(--color-foreground);
	}
	.csm-eyebrow {
		display: inline-flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.35em 0.7em;
		margin: 0 0 clamp(1rem, 2.5vw, 1.5rem);
		font-family: var(--font-mono);
		font-size: var(--text-xsmall);
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: var(--color-subtle);
	}
	/* The jewel belongs to the studio designation (owner round 3): it rides
	   INSIDE the role unit, hugging "Digital design studio" — not the location. */
	.csm-eyebrow-role {
		display: inline-flex;
		align-items: center;
		gap: 0.55em;
	}
	.csm-eyebrow-loc {
		color: var(--color-faint);
	}
	.csm-title {
		margin: 0;
		font-family: var(--font-primary);
		font-weight: 600;
		font-size: var(--text-headline);
		line-height: 1.05;
		letter-spacing: -0.04em;
		color: var(--color-foreground);
		text-wrap: balance;
	}
	.csm-lede {
		margin: clamp(0.85rem, 2vw, 1.25rem) 0 0;
		max-width: 36ch;
		font-family: var(--font-body);
		font-size: var(--text-body);
		line-height: 1.6;
		color: var(--color-muted);
		text-wrap: balance;
	}
	.csm-datum {
		margin: clamp(1.5rem, 3.5vw, 2.25rem) 0 0;
		font-family: var(--font-mono);
		font-size: var(--text-annotation);
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-primary-light);
		font-variant-numeric: tabular-nums;
	}
	.csm-contact {
		margin: clamp(1.25rem, 3vw, 1.75rem) 0 0;
		max-width: 44ch;
		font-family: var(--font-body);
		font-size: var(--text-annotation);
		line-height: 1.55;
		color: var(--color-subtle);
		text-wrap: balance;
	}
	.csm-cta {
		margin: clamp(0.6rem, 1.5vw, 0.9rem) 0 0;
		font-family: var(--font-body);
		font-size: var(--text-body);
		line-height: 1.5;
	}
	.csm-cta a {
		color: var(--color-primary-light);
		text-decoration: none;
		border-bottom: 1px solid rgb(var(--color-primary-rgb) / 0.35);
		transition: border-color 0.3s var(--ease-fade);
	}
	.csm-cta a:hover {
		border-color: var(--color-primary-light);
	}

	/* ---- Mobile (≤430px): tuck the clock tighter to the corner ------------ */
	@media (max-width: 430px) {
		.csm-clock {
			top: clamp(1rem, 3.5vw, 1.5rem);
		}
	}
</style>

<script>
	// ── Merged coming-soon: manifesto (zone 1) → monolith (zone 2). ─────────
	const root = document.querySelector<HTMLElement>('[data-csm]')
	if (root) {
		const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
		const allowMotion = !reduce

		// --- The one live clock (top-right corner) --------------------------
		const clock = root.querySelector<HTMLElement>('[data-cs-countdown]')
		if (clock) {
			const t = new Date(
				clock.dataset.csTarget ?? '2026-07-24T17:00:00+01:00'
			).getTime()
			const set = (unit: string, val: number) => {
				const el = clock.querySelector<HTMLElement>(`[data-unit="${unit}"]`)
				if (el) el.textContent = String(val).padStart(2, '0')
			}
			const tick = () => {
				const diff = Math.max(0, t - Date.now())
				set('days', Math.floor(diff / 86400000))
				set('hours', Math.floor((diff % 86400000) / 3600000))
				set('minutes', Math.floor((diff % 3600000) / 60000))
				set('seconds', Math.floor((diff % 60000) / 1000))
			}
			tick()
			clock.dataset.live = '1'
			window.setInterval(tick, 1000)
		}

		// --- The stage light follows the pointer (fine pointers, lerped) -----
		// §7 Pointer Field restraint: the light's origin drifts a few rem toward
		// the cursor through a rAF lerp (quickTo-class smoothing) — never 1:1.
		// Touch and reduced-motion keep the static composed light.
		const lightCore = root.querySelector<HTMLElement>('.csm-light-core')
		const finePointer = window.matchMedia('(pointer: fine)').matches
		if (lightCore && allowMotion && finePointer) {
			let tx = 0
			let ty = 0
			let cx = 0
			let cy = 0
			let live = false
			const step = () => {
				cx += (tx - cx) * 0.07
				cy += (ty - cy) * 0.07
				lightCore.style.setProperty('--lx', cx.toFixed(2) + 'px')
				lightCore.style.setProperty('--ly', cy.toFixed(2) + 'px')
				if (Math.abs(tx - cx) + Math.abs(ty - cy) > 0.15) {
					window.requestAnimationFrame(step)
				} else {
					live = false
				}
			}
			window.addEventListener(
				'pointermove',
				(e) => {
					tx = (e.clientX / window.innerWidth - 0.5) * 90
					ty = (e.clientY / window.innerHeight - 0.5) * 64
					if (!live) {
						live = true
						window.requestAnimationFrame(step)
					}
				},
				{ passive: true }
			)
		}

		// --- Clicking hello@ = the light swells for a beat ("we're open") ----
		let swellT = 0
		root.querySelectorAll<HTMLAnchorElement>('a[href^="mailto:"]').forEach((a) =>
			a.addEventListener('click', () => {
				if (!allowMotion) return
				root.dataset.csmSwell = '1'
				window.clearTimeout(swellT)
				swellT = window.setTimeout(() => {
					delete root.dataset.csmSwell
				}, 1500)
			})
		)

		// --- Zone flag: hide the corner clock once the monolith dominates ---
		// Driven off the monolith's own rect (not the 'scroll' source), so it
		// updates for BOTH user and programmatic (auto-descent) scrolling — the
		// distinction that matters for descent-yielding lives in INTENT events
		// (wheel/touch/key/pointer), never in the scroll event itself.
		const monolith = root.querySelector<HTMLElement>('.csm-monolith')
		if (monolith) {
			let ticking = false
			const syncZone = () => {
				ticking = false
				const inZone2 =
					monolith.getBoundingClientRect().top <= window.innerHeight * 0.5
				root.dataset.csmZone = inZone2 ? '2' : '1'
			}
			const onScroll = () => {
				if (ticking) return
				ticking = true
				requestAnimationFrame(syncZone)
			}
			window.addEventListener('scroll', onScroll, { passive: true })
			window.addEventListener('resize', onScroll)
			syncZone()

			// --- The choreographed descent + the manifesto cycler -----------
			// Both are motion; RM keeps the static composed page (both zones
			// visible, first stanza shown, no descent).
			if (allowMotion) {
				// --- Zone-2 story: JS scrub fallback where view-timeline is absent ---
				// CSS animation-timeline: view() drives zone 2 where supported. Some
				// mobile engines (notably Safari) lack it, so there the SAME
				// choreography (orbit turn, rise, floor draw, staggered rev lifts)
				// runs off scroll via JS — every browser gets the identical
				// scroll-driven turn. ROUND 5: the raw per-event write read as
				// steppy on phones (touch scroll events arrive coarse), so the
				// progress now runs through a LERPED FOLLOWER (one-pole, ~150ms
				// time-constant — the house smoothing pattern): scroll updates only
				// the TARGET; a rAF loop eases current → target and writes the
				// transforms, then parks itself when converged. The prism's 26s
				// idle turn (CSS, on .csm-prism INSIDE the orbit wrapper) is
				// untouched by this path and composes with the scrubbed orbit
				// exactly as on the CSS path. Mobile-stick law: passive listeners,
				// rect READS only (never scroll writes), transforms set inline off
				// rAF. Forceable for test via ?csm-scrub=js.
				const supportsVT =
					!!window.CSS &&
					typeof window.CSS.supports === 'function' &&
					window.CSS.supports('animation-timeline: view()')
				const forceJs =
					new URLSearchParams(window.location.search).get('csm-scrub') === 'js'
				if (!supportsVT || forceJs) {
					root.classList.add('csm-scrub-js')
					const orbit = root.querySelector<HTMLElement>('.csm-orbit')
					const stage3d = root.querySelector<HTMLElement>('.csm-stage3d')
					const floorEl = root.querySelector<HTMLElement>('.csm-floor')
					const revs = Array.from(root.querySelectorAll<HTMLElement>('.csm-rev'))
					// [from, to] cover fractions — mirror the CSS animation-range values
					// (all ends ≤0.42, the round-5 completes-at-max-scroll guarantee).
					const revRanges: [number, number][] = [
						[0.14, 0.25],
						[0.17, 0.28],
						[0.2, 0.31],
						[0.23, 0.34],
						[0.26, 0.36],
						[0.29, 0.39],
						[0.32, 0.42],
					]
					const clamp01 = (x: number) => (x < 0 ? 0 : x > 1 ? 1 : x)
					const sub = (p: number, a: number, b: number) => clamp01((p - a) / (b - a))
					// Pre-arm the clip masks + from-poses so nothing flashes finished.
					revs.forEach((r) => {
						r.style.clipPath = 'inset(-0.3em -0.3em -0.1em -0.3em)'
					})
					const apply = (p: number) => {
						root.style.setProperty('--z2p', p.toFixed(4))
						if (orbit) {
							// CONTINUOUS turntable — mobile parity with desktop's always-live
							// feel (fix 2026-07-09). The orbit rotation tracks scroll across the
							// WHOLE reachable range and stays reversible from ANY position; it is
							// NOT parked once the arrival completes. The old sub(p, 0, 0.42)
							// clamped at 1, so past ~42% cover the prism stopped answering scroll
							// (the "doesn't keep rotating on mobile" fault). `po` keeps the exact
							// desktop arrival RATE (rotateY −150°→0° over cover 0→42%) but is only
							// floored at 0, never capped at 1 — so scrolling on past the arrival
							// keeps turning the prism and scrolling back up rewinds it. The value
							// passed in is the smoothed `cur` from the one-pole follower below, so
							// the coupling is fluid, not steppy; the prism's 26s CSS idle turn
							// composes inside this wrapper exactly as it does on desktop.
							const po = Math.max(0, p / 0.42)
							const ax = 7 * (1 - Math.min(1, po))
							const ay = -150 * (1 - po)
							orbit.style.transform =
								'rotateX(' + ax.toFixed(2) + 'deg) rotateY(' + ay.toFixed(2) + 'deg)'
						}
						if (stage3d) {
							const pr = sub(p, 0.02, 0.3)
							stage3d.style.opacity = pr.toFixed(3)
							stage3d.style.transform =
								'translateY(' +
								(9 * (1 - pr)).toFixed(2) +
								'vh) scale(' +
								(0.9 + 0.1 * pr).toFixed(3) +
								')'
						}
						if (floorEl) {
							const pf = sub(p, 0.08, 0.34)
							floorEl.style.transform =
								'translateX(-50%) scaleX(' + pf.toFixed(3) + ')'
						}
						revs.forEach((r, i) => {
							const child = r.firstElementChild as HTMLElement | null
							if (!child) return
							const [a, b] = revRanges[i] ?? [0, 1]
							const pl = sub(p, a, b)
							child.style.transform =
								'translateY(' + (130 * (1 - pl)).toFixed(2) + '%)'
						})
					}
					// cover progress: 0 as the monolith top meets the viewport bottom,
					// 1 as its bottom leaves the viewport top (matches CSS `cover`).
					// vhCache: viewport height, refreshed only on resize/orientation
					// (2026-07-09). Reading window.innerHeight every scroll tick makes the
					// mapping jitter on iOS Safari (the URL bar collapses mid-scroll and
					// innerHeight wobbles frame-to-frame) — a source of the "jumpy" feel.
					// rect.top stays the live scroll signal; vh is stable within a gesture.
					let vhCache = window.innerHeight || 1
					const readP = () => {
						const rect = monolith.getBoundingClientRect()
						return clamp01((vhCache - rect.top) / (rect.height + vhCache))
					}
					// The follower: cur chases target with a ~150ms one-pole ease.
					let target = readP()
					let cur = target
					apply(cur) // settle the on-load pose instantly — no lerp-in
					let running = false
					let lastT = 0
					const TAU = 0.15
					const follow = (now: number) => {
						const dt = Math.min(0.1, (now - lastT) / 1000)
						lastT = now
						cur += (target - cur) * (1 - Math.exp(-dt / TAU))
						if (Math.abs(target - cur) < 0.0004) {
							cur = target
							apply(cur)
							running = false
							return
						}
						apply(cur)
						window.requestAnimationFrame(follow)
					}
					const wake = () => {
						target = readP()
						if (!running) {
							running = true
							lastT = performance.now()
							window.requestAnimationFrame(follow)
						}
					}
					window.addEventListener('scroll', wake, { passive: true })
					const onViewportResize = () => {
						vhCache = window.innerHeight || 1
						wake()
					}
					window.addEventListener('resize', onViewportResize)
					window.addEventListener('orientationchange', onViewportResize)
				}

				let userEngaged = false
				let descentActive = false
				let raf = 0

				const cancelDescent = () => {
					if (descentActive) {
						descentActive = false
						window.cancelAnimationFrame(raf)
						root.dataset.csmDescent = 'yielded'
					}
				}
				// Genuine scroll INTENT yields the auto-descent to the user and
				// disarms it — the user always wins. Programmatic scrollTo never
				// emits these, so the descent never cancels itself.
				const onIntent = () => {
					userEngaged = true
					cancelDescent()
				}
				;(['wheel', 'touchstart', 'keydown', 'pointerdown'] as const).forEach(
					(ev) => window.addEventListener(ev, onIntent, { passive: true })
				)

				const startDescent = () => {
					if (userEngaged || descentActive) return
					if (root.dataset.csmDescent !== 'idle') return
					// Only from the top — never a scroll-jack mid-reading.
					if (window.scrollY > window.innerHeight * 0.25) return
					const startY = window.scrollY
					const targetY = Math.round(
						monolith.getBoundingClientRect().top + window.scrollY
					)
					const dist = targetY - startY
					if (dist <= 2) {
						root.dataset.csmDescent = 'done'
						return
					}
					descentActive = true
					root.dataset.csmDescent = 'running'
					// Scale the carry with the (now longer, runway-extended) distance so
					// the descent keeps its unhurried velocity instead of racing across
					// the added seam. Floored at the original 2.2s, capped at 3.6s.
					const dur = Math.round(Math.min(3600, Math.max(2200, dist * 2.2)))
					const t0 = performance.now()
					const ease = (p: number) => 1 - Math.pow(1 - p, 3) // easeOutCubic
					const stepFrame = (now: number) => {
						if (!descentActive) return
						const p = Math.min(1, (now - t0) / dur)
						root.dataset.csmProgress = p.toFixed(3)
						window.scrollTo(0, startY + dist * ease(p))
						if (p < 1) {
							raf = window.requestAnimationFrame(stepFrame)
						} else {
							descentActive = false
							root.dataset.csmDescent = 'done'
						}
					}
					raf = window.requestAnimationFrame(stepFrame)
				}

				const stage = root.querySelector<HTMLElement>('[data-csm-ticker]')
				const stmts = stage
					? Array.from(
							stage.querySelectorAll<HTMLElement>('.csm-stmt:not(.csm-ghost)')
						)
					: []

				if (stmts.length > 1) {
					let idx = 0
					const DWELL = 3400
					const OUT = 620
					let timer = 0

					const advance = () => {
						// The manifesto has spoken its whole piece (last stanza read):
						// if the reader is idle at the top, hand off into the descent
						// and hold the closing line — the type carries you down.
						if (
							idx === stmts.length - 1 &&
							!userEngaged &&
							root.dataset.csmDescent === 'idle' &&
							window.scrollY <= window.innerHeight * 0.25
						) {
							root.dataset.csmCycle = '1'
							window.clearInterval(timer)
							startDescent()
							return
						}
						const cur = stmts[idx]
						const next = stmts[(idx + 1) % stmts.length]
						cur.classList.remove('is-in')
						cur.classList.add('is-out')
						cur.setAttribute('aria-hidden', 'true')
						window.setTimeout(() => {
							cur.classList.remove('is-out')
							next.classList.add('is-in')
							next.removeAttribute('aria-hidden')
							idx = (idx + 1) % stmts.length
							if (idx === 0)
								root.dataset.csmCycle = String(Number(root.dataset.csmCycle || '0') + 1)
						}, OUT)
					}

					timer = window.setInterval(advance, DWELL)
					// Pause while hidden so stanzas don't stack up on return.
					document.addEventListener('visibilitychange', () => {
						window.clearInterval(timer)
						if (!document.hidden) timer = window.setInterval(advance, DWELL)
					})
				}
			}
		}
	}
